{
  "name": "dungeons",
  "private": true,
  "version": "0.7.3",
  "type": "module",
  "description": "A browser-based roguelike dungeon crawler (Phaser + Vite PWA).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node e2e/runner.mjs",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\" \"server/**/*.js\" eslint.config.js",
    "format": "prettier --write \"**/*.{js,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\" \"server/**/*.js\"",
    "balance": "node scripts/balance-sim.js"
  },
  "dependencies": {
    "phaser": "^3.88.2"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "playwright-core": "^1.56.1",
    "prettier": "^3.9.5",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.9"
  }
}
